# Copie para .streamlit/secrets.toml NO SEU PC (não vai para o Git).
# Streamlit Cloud: Settings → Secrets — mesmo conteúdo.

# --- Forma A: um URI só (simples para Home.py / db.py) ---
# DB_URL = "postgresql://postgres:SENHA@db.xxxxx.supabase.co:5432/postgres?sslmode=require"

# --- Forma B: campos (igual ao que db_config.py espera; db.py também monta o URI) ---
DB_HOST = "db.xxxxx.supabase.co"
DB_NAME = "postgres"
DB_USER = "postgres"
DB_PASS = "COLOQUE_A_SENHA_QUE_DEFINIU_NO_SUPABASE"
DB_PORT = "5432"
DB_SSLMODE = "require"
