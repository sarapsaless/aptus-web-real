# Copie para secrets.toml no seu PC (não faça commit).
#
# --- Se aparecer ERRO DE TIMEOUT na porta 5432 (Windows / rede IPv4) ---
# No Supabase: projeto → botão Connect → escolha "Transaction pooler" ou "Session pooler".
# Cole essa URI completa em DB_URL (host tipo *.pooler.supabase.com, porta 6543 ou 5432).
# A ligação DIRECTA db.PROJECT.supabase.co:5432 falha em muitas redes domésticas.
#
# Documentação: https://supabase.com/docs/guides/database/connecting-to-postgres

# Opcional: segundos para tentar ligar (predefinição 30)
# PG_CONNECT_TIMEOUT = "45"

# --- Forma A (recomendada): uma URI só ---
# DB_URL = "postgresql://postgres.PROJECTREF:SENHA@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require"

# --- Forma B: campos separados (use host/porta do POOLER se tiver timeout) ---
# DB_HOST = "aws-0-eu-central-1.pooler.supabase.co"
# DB_PORT = "6543"
# DB_NAME = "postgres"
# DB_USER = "postgres.PROJECTREF"
# DB_PASS = "SENHA_DA_BASE"
# DB_SSLMODE = "require"
